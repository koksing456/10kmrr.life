{
  "cases": [
    {
      "name": "mixed recurring intervals and exclusions",
      "subscriptions": [
        {
          "id": "sub_mock_mixed",
          "status": "active",
          "items": {
            "data": [
              {
                "quantity": 2,
                "price": {
                  "currency": "usd",
                  "unit_amount": 10000,
                  "recurring": {
                    "interval": "month",
                    "interval_count": 1,
                    "usage_type": "licensed"
                  }
                }
              },
              {
                "quantity": 1,
                "price": {
                  "currency": "usd",
                  "unit_amount": 120000,
                  "recurring": {
                    "interval": "year",
                    "interval_count": 1,
                    "usage_type": "licensed"
                  }
                }
              },
              {
                "quantity": 1,
                "price": {
                  "currency": "usd",
                  "unit_amount": 2300,
                  "recurring": {
                    "interval": "week",
                    "interval_count": 1,
                    "usage_type": "licensed"
                  }
                }
              },
              {
                "quantity": 1,
                "price": {
                  "currency": "usd",
